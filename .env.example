# ─────────────────────────────────────────────────────────────────
# VoxTrail — Environment Configuration Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Google AI / Gemini ───────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Authentication ────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_minimum_32_chars
# Must be exactly 16 bytes for AES-128
AES_SECRET_KEY=MySecretKey12345

# ── Azure AD (Enterprise Auth — optional) ────────────────────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-01-preview
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-4o-realtime-preview
AZURE_OPENAI_API_REALTIME_KEY=

# ── SAP Integration (optional for full booking flow) ─────────────
SAP_BASE_URL=https://your-sap-instance.com
SAP_API_KEY=
SAP_CLIENT=100

# ── Database (persistent chat store) ─────────────────────────────
DATABASE_URL=sqlite:///./voxtrail.db
# For production: postgresql://user:pass@host:5432/voxtrail

# ── Observability (optional) ──────────────────────────────────────
PHOENIX_OTLP_ENDPOINT=http://localhost:6006/v1/traces
OTEL_SDK_DISABLED=false

# ── App Settings ──────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_MINUTES=120
DEFAULT_DAYS_LOOKBACK=365
